{
  "name": "pi-station",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-Station platform — MeetStation is the first edge app",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "shared",
    "core",
    "hardware",
    "apps/meet-station"
  ],
  "scripts": {
    "dev": "node --import tsx/esm apps/meet-station/src/index.ts",
    "build": "tsc -b",
    "start": "node apps/meet-station/dist/index.js",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --config apps/meet-station/vitest.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  }
}
