# Core
APP_ID=meet-station
NODE_ENV=development
PORT=3456
HOST=0.0.0.0
STATION_ID=MPS-001
STATION_NAME=MeetPaper Station 001

# ─── Data directories ────────────────────────────────────────────────────────
# Dev (local): relative paths inside the app dir
# Pi (production): absolute paths OUTSIDE the app dir — survives deploys
#
# Dev:        DATA_DIR=./data
# Pi:         DATA_DIR=/home/pistation/data/meet-station
#
# Structure on Pi:
#   /home/pistation/data/meet-station/
#     sessions/{session_id}/audio/chunk-NNNN.wav
#     sessions/{session_id}/video/chunk-NNNN.mp4
#     sessions/{session_id}/transcripts/whisper-{ts}.txt
#     sessions/{session_id}/faces/{chunk_index}-faces.json
#     sqlite/station.sqlite
#     reports/{session_id}.json
#
DATA_DIR=./data
SQLITE_PATH=./data/sqlite/station.sqlite
AUDIO_DIR=./data/sessions
VIDEO_DIR=./data/sessions
FACES_DIR=./data/sessions
REPORTS_DIR=./data/reports

# Audio
AUDIO_SOURCE=mock            # mock | arecord | file
AUDIO_DEVICE=plughw:1,0      # Pi: confirm with `arecord -l` (M-305 = plughw:2,0 on this Pi)
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SECONDS=30
AUDIO_FILE_PATH=

# Speech-to-text
STT_PROVIDER=mock            # mock | elevenlabs | faster-whisper
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=scribe_v2_realtime
ELEVENLABS_LANGUAGE_CODE=en
ELEVENLABS_INCLUDE_TIMESTAMPS=true

# faster-whisper (local batch STT — better accuracy than Vosk, runs fully offline)
# base.en = ~145MB, good quality. small.en = ~466MB, better for professional events.
FASTER_WHISPER_MODEL=base.en
FASTER_WHISPER_SCRIPT=scripts/transcribe.py
# Python that has faster-whisper installed.
# Pi: /home/pistation/pi-station/venv-whisper/bin/python3
# Dev: python3 (system)
FASTER_WHISPER_PYTHON=python3
# If set, the venv's bin/python3 is used instead of FASTER_WHISPER_PYTHON.
# Pi: /home/pistation/pi-station/venv-whisper
FASTER_WHISPER_VENV_DIR=
# Subprocess timeout = this multiplier x chunk duration.
FASTER_WHISPER_TIMEOUT_MULTIPLIER=5

# ApresMeet / Voice Intelligence ingest
VOICE_INGEST_URL=http://localhost:3456/mock/ingest
VOICE_INGEST_TOKEN=dev-token
VOICE_INGEST_TIMEOUT_MS=5000

# Pairing
PAIRING_MODE=local           # local | remote
STATION_PAIRING_URL=
STATION_PAIRING_TOKEN=

# Relay behaviour
RELAY_FLUSH_INTERVAL_MS=2000
RELAY_MAX_ATTEMPTS=50
RELAY_INITIAL_BACKOFF_MS=1000
RELAY_MAX_BACKOFF_MS=30000

# Demo simulation
ENABLE_MOCK_INGEST=true
MOCK_INGEST_AVAILABLE=true

# Sync to cloud (S3 via presigned URLs from apm/PHP — Pi holds no AWS credentials)
# Production: STATION_SYNC_URL=https://voice.apresmeet.com/ws/station
STATION_SYNC_URL=http://localhost:3456/mock/station
SYNC_HEALTH_URL=http://localhost:3456/health
SYNC_PART_SIZE=5242880
CONNECTIVITY_PROBE_INTERVAL_MS=10000
AWS_REGION=eu-west-2

# ─── Video capture (J6) ──────────────────────────────────────────────────────
VIDEO_SOURCE=mock            # mock | libcamera
VIDEO_DEVICE=/dev/video0
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30
VIDEO_CHUNK_SECONDS=30       # rotate MP4 every 30s, same cadence as audio
VIDEO_BITRATE=2000000        # 2 Mbps = ~900MB/hr at 720p30

# Face detection (J6)
# mock: simulated face positions (no camera needed)
# hailo: AI HAT+ 26 TOPS NPU via rpicam-apps (30fps, zero CPU overhead)
FACE_DETECTION=mock          # mock | hailo
HAILO_POST_PROCESS_FILE=/usr/share/rpi-camera-assets/hailo_yolov8_inference.json

# Pan/tilt servo tracking (J6)
# mock: logs position changes (no hardware needed)
# pca9685: drives MG996R (pan) + SG90 (tilt) via PCA9685 over I2C
# Power: servos need separate 5V supply — NEVER power from Pi GPIO pins (3.3V only)
PAN_TILT=mock                # mock | pca9685
PAN_TILT_I2C_BUS=1
PAN_TILT_I2C_ADDRESS=0x40
PAN_TILT_PAN_CHANNEL=0       # PCA9685 channel 0 = MG996R pan servo
PAN_TILT_TILT_CHANNEL=1      # PCA9685 channel 1 = SG90 tilt servo
PAN_TILT_PAN_MIN=30
PAN_TILT_PAN_MAX=150
PAN_TILT_TILT_MIN=60
PAN_TILT_TILT_MAX=120
PAN_TILT_NEUTRAL_PAN=90      # centre
PAN_TILT_NEUTRAL_TILT=90
PAN_TILT_DEADZONE_PX=20      # don't move if face within ±20px of frame centre
PAN_TILT_SMOOTHING=0.3       # low-pass filter (0=instant snap, 1=no movement)

# ─── Hardware / GPIO ─────────────────────────────────────────────────────────
ENABLED_COMPONENTS=voice     # voice | voice,video
ENABLE_GPIO=false
GPIO_CHIP=gpiochip0
GPIO_RED_PIN=17
GPIO_TEAL_PIN=27
GPIO_AMBER_PIN=22
GPIO_WHITE_PIN=24
GPIO_BUTTON_PIN=23
