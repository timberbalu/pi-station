# Environment — copy to .env and fill in values
# Never commit .env

# ElevenLabs
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_WS_URL=wss://api.elevenlabs.io/v1/speech-to-text/stream

# MeetPaper Voice Intelligence endpoint
VI_INGEST_URL=https://voice.apresmeet.com/ws/station/ingest
VI_SESSION_TOKEN=

# pi-control API
CONTROL_PORT=3456
CONTROL_HOST=0.0.0.0

# Local buffer
BUFFER_DIR=./buffer
SQLITE_PATH=./queue.db

# Logging
LOG_LEVEL=info
